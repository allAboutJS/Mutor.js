{
  "name": "mutorjs",
  "version": "3.0.0",
  "description": "A fast synchronous templating engine for Node.js and the browser.",
  "homepage": "https://github.com/allAboutJS/Mutor.js#readme",
  "bugs": {
    "url": "https://github.com/allAboutJS/Mutor.js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/allAboutJS/Mutor.js.git"
  },
  "license": "ISC",
  "author": "Onah Victor",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "browser": "./dist/mutor.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs",
      "default": "./dist/server.js"
    }
  },
  "bin": {
    "mutor": "./dist/cli.cjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "husky && npm run build",
    "benchmarks": "npm run build && tsx src/__tests__/benchmarks.ts",
    "test": "jest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/benchmark": "^2.1.5",
    "@types/ejs": "^3.1.5",
    "@types/handlebars": "^4.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/nunjucks": "^3.2.6",
    "benchmark": "^2.1.4",
    "ejs": "^5.0.1",
    "eta": "^4.6.0",
    "handlebars": "^4.7.8",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.2.7",
    "nunjucks": "^3.2.4",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "*.{js,ts,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {},
  "keywords": [
    "Template",
    "Engine",
    "AST",
    "Parser"
  ],
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
